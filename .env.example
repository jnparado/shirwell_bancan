## Site
# NEXT_PUBLIC_SITE_URL=https://shirwell.com
#
## Google
# HTML meta tag content from Search Console (optional)
# GOOGLE_SITE_VERIFICATION=
#
# Google Analytics 4 (gtag.js) — measurement ID from GA / Tag Assistant
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-35YK4VRJC0
#
## Google AdSense (web)
# From AdSense Account information / Sites:
# Publisher ID in UI looks like: pub-2495432679632375
# This env var must include the "ca-" prefix: ca-pub-2495432679632375
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-2495432679632375
#
# Optional: Display ad unit slot id (a number) if you are placing <AdSenseUnit /> blocks.
# Create it in AdSense → Ads → By ad unit → Display.
# NEXT_PUBLIC_ADSENSE_SLOT_BANNER=1234567890

## Google AdMob (native Android/iOS app wrapper — not used by Next.js web pages)
# App ID (from AdMob app settings):
ADMOB_APP_ID=ca-app-pub-2495432679632375~1624956947
# App Open ad unit id:
ADMOB_APP_OPEN_AD_UNIT_ID=ca-app-pub-2495432679632375/6559609049
# Another AdMob ad unit id (from the Ad unit creation screen / mediation mapping):
ADMOB_AD_UNIT_ID=ca-app-pub-2495432679632375/4899465892

